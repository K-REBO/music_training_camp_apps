# ─── Rust バックエンド ───────────────────────────────
PORT=8001
DATABASE_URL=sqlite:/data/reservation.db
STATIC_DIR=./reservation/build
ALLOWED_ORIGINS=http://localhost:8001,https://tc.bido.dev

# 管理者パスワード（椎木知仁のログイン用）
ADMIN_PASSWORD=admin123

# ─── LINE 通知 ────────────────────────────────────────
# LINE Developers コンソールで取得
LINE_CHANNEL_ACCESS_TOKEN=
LINE_CHANNEL_SECRET=

# ─── Cloudflare Tunnel ────────────────────────────────
# Cloudflare Dashboard > Zero Trust > Networks > Tunnels で取得
CLOUDFLARE_TUNNEL_TOKEN=
