{
  "imports": {
    "@std/": "https://deno.land/std@0.214.0/",
    "@fresh/": "https://deno.land/x/fresh@1.6.8/"
  },
  "tasks": {
    "dev": "deno run --allow-all --unstable-kv main.ts",
    "start": "deno run --allow-all --unstable-kv main.ts",
    "seed": "deno run --allow-all --unstable-kv scripts/seed.ts",
    "kv-server": "deno run --allow-all --unstable-kv scripts/kv-server.ts"
  },
  "compilerOptions": {
    "jsx": "react-jsx",
    "jsxImportSource": "preact",
    "lib": ["dom", "dom.iterable", "deno.ns"]
  },
  "unstable": ["kv"]
}