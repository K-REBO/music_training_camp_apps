# Environment Configuration - Phase 4: Rust バックエンド版
# このファイルをコピーして .env を作成し、実際の値を設定してください
#   cp reservation/.env.example reservation/.env

# ── サーバー設定 ──────────────────────────────────────────────
PORT=5173

# ── データベース ──────────────────────────────────────────────
# SQLite DB のパス（rust-backend バイナリ起動ディレクトリからの相対、または絶対パス）
DATABASE_URL=sqlite:/home/rpi/music_training_camp_apps/shared/database/reservation_sqlite.db

# ── 静的ファイル ──────────────────────────────────────────────
# SvelteKit ビルド成果物のディレクトリ
STATIC_DIR=/home/rpi/music_training_camp_apps/reservation/build

# ── 管理者認証 ────────────────────────────────────────────────
# 椎木知仁ログイン時に要求するパスワード
ADMIN_PASSWORD=your-admin-password-here

# ── LINE 通知 ─────────────────────────────────────────────────
LINE_CHANNEL_ACCESS_TOKEN=your-line-channel-access-token-here

# ── CORS（開発時のみ。本番は同一オリジンのため不要） ──────────
# ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173
