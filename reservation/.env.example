# Environment Configuration Example
# .env.local ファイルを作成してローカル設定を上書き可能

# Development Settings
VITE_NODE_ENV=development
VITE_WS_HOST=localhost
VITE_WS_PORT=8001
VITE_API_HOST=localhost
VITE_API_PORT=8001

# Production Settings (Deno Deploy)
# VITE_NODE_ENV=production
# VITE_WS_HOST=your-app.deno.dev
# VITE_WS_PORT=
# VITE_API_HOST=your-app.deno.dev
# VITE_API_PORT=